{
  "name": "@kunlun/pw",
  "version": "0.1.0",
  "private": true,
  "description": "Pi-昆仑 L7 持久战策略引擎 — 论持久战：防御→相持→反攻三阶段策略",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && node /root/pi-kunlun/scripts/fix-esm-imports.mjs ./dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@kunlun/ternary": "workspace:*",
    "@kunlun/contradiction": "workspace:*",
    "@kunlun/spiral": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0"
  }
}
