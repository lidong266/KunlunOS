{
  "name": "@kunlun/presence",
  "version": "0.1.0",
  "private": true,
  "description": "Pi-昆仑 L1+L4 认知在场层 — CognitivePresence/IPresenceManager/距离场",
  "type": "module",
  "main": "./dist/index.js",
