{
  "name": "@kunlun/subsystems",
  "version": "0.1.0",
  "private": true,
  "description": "Pi-昆仑 L3 认知子系统 — 谛听/太一/天工/琅嬛/归藏/镇岳/镇熵/玄关 三元化改造",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./diting": {
      "import": "./dist/diting/index.js",
      "types": "./dist/diting/index.d.ts"
    },
    "./taiyi": {
      "import": "./dist/taiyi/index.js",
      "types": "./dist/taiyi/index.d.ts"
    },
    "./tiangong": {
      "import": "./dist/tiangong/index.js",
      "types": "./dist/tiangong/index.d.ts"
    },
    "./langhuan": {
      "import": "./dist/langhuan/index.js",
      "types": "./dist/langhuan/index.d.ts"
    },
    "./guicang": {
      "import": "./dist/guicang/index.js",
      "types": "./dist/guicang/index.d.ts"
    },
    "./zhenyue": {
      "import": "./dist/zhenyue/index.js",
      "types": "./dist/zhenyue/index.d.ts"
    },
    "./zhenshang": {
      "import": "./dist/zhenshang/index.js",
      "types": "./dist/zhenshang/index.d.ts"
    },
    "./xuanguan": {
      "import": "./dist/xuanguan/index.js",
      "types": "./dist/xuanguan/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && node ../../scripts/fix-esm-imports.mjs ./dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@kunlun/contradiction": "workspace:*",
    "@kunlun/eventbus": "workspace:*",
    "@kunlun/presence": "workspace:*",
    "@kunlun/ternary": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^2.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
